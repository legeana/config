prefix ~/.ssh

if tags 'distro!=unraid' {
    symlink config
    symlink_tree config.d
} else {
    raw_copy config
    mkdir config.d
    # TODO: config.d contents
}

if is_linux {
    if tags 'feature=wsl' {
        subdir wsl
    } else if tags 'distro=unraid' {
        subdir unraid
    } else {
        subdir linux
    }
} else if is_macos {
    subdir macos
} else if is_windows {
    subdir windows
}
