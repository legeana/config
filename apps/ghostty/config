# Can be reloaded via
# - Linux: ctrl+shift+,
# - MacOS: cmd+shift+,
# See https://ghostty.org/docs/config#reloading-the-configuration.

cursor-style = block
font-family = Hack Nerd Font
right-click-action = copy
scrollback-limit = 10000
theme = Kitty Default

# Bash is the original shell, fish is started later.
shell-integration = none
shell-integration-features = no-cursor
